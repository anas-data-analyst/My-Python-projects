      "source": [
        "def check_even_or_odd(numbers):\n",
        "  for n in numbers:\n",
        "    if n % 2 == 0:\n",
        "      print(f\"{n} is even\")\n",
        "    elif n%2!= 0:\n",
        "      print(f\"{n} is odd\")\n",
        "my_result = [24,68,105,283,555]\n",
        "check_even_or_odd(my_result)\n",
        "print(my_result)"
      ]
